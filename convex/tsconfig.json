{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "./_generated"
  },
  "include": ["./**/*.ts", "./**/*.js"],
  "exclude": ["./_generated"]
}
