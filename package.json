{
  "name": "fellowship42",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @fellowship42/app dev",
    "dev:worker": "pnpm --filter @fellowship42/worker dev",
    "dev:web": "pnpm --filter @fellowship42/web dev",
    "dev:convex": "pnpm exec convex dev",
    "codegen:convex": "pnpm exec convex codegen",
    "build": "pnpm -r --if-present build",
    "build:worker": "pnpm --filter @fellowship42/worker build",
    "build:web": "pnpm --filter @fellowship42/web build",
    "typecheck": "pnpm typecheck:workspaces && pnpm typecheck:convex",
    "typecheck:workspaces": "pnpm -r --if-present typecheck",
    "typecheck:convex": "pnpm exec tsc -p convex/tsconfig.json --noEmit",
    "deploy:worker": "pnpm --filter @fellowship42/worker deploy"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "convex": "^1.34.0",
    "typescript": "^5.7.0"
  }
}
