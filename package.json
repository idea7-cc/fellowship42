{
  "name": "fellowship42",
  "version": "0.11.0",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "prepare": "pnpm build:contracts && pnpm --filter @fellowship42/f42ctl build",
    "dev": "pnpm build:contracts && pnpm --filter @fellowship42/instance dev",
    "dev:instance": "pnpm build:contracts && pnpm --filter @fellowship42/instance dev",
    "dev:site": "pnpm --filter @fellowship42/project-site dev",
    "build:contracts": "pnpm --filter @fellowship42/management-protocol build",
    "build": "pnpm -r --if-present build",
    "build:site": "pnpm --filter @fellowship42/project-site build",
    "typecheck": "pnpm build:contracts && pnpm -r --if-present typecheck",
    "test": "pnpm build:contracts && pnpm -r --if-present test",
    "test:migration-rehearsal": "pnpm build:contracts && pnpm --filter @fellowship42/f42ctl build && node scripts/rehearse-hosted-to-church-owned.mjs",
    "check:architecture": "node scripts/check-repository-boundaries.mjs",
    "cf-typegen": "pnpm --filter @fellowship42/instance cf-typegen",
    "cf-typegen:check": "pnpm --filter @fellowship42/instance cf-typegen:check",
    "db:migrate": "pnpm --filter @fellowship42/instance db:migrate",
    "db:migrate:remote": "pnpm --filter @fellowship42/instance db:migrate:remote",
    "db:seed": "pnpm --filter @fellowship42/instance db:seed",
    "deploy:dry-run": "pnpm --filter @fellowship42/instance deploy:dry-run",
    "deploy": "pnpm --filter @fellowship42/instance deploy",
    "deploy:site:dry-run": "pnpm --filter @fellowship42/project-site deploy:dry-run",
    "deploy:site": "pnpm --filter @fellowship42/project-site deploy",
    "release:assemble": "node scripts/build-release-artifacts.mjs && node scripts/verify-release-artifacts.mjs",
    "release:artifacts": "pnpm build && pnpm release:assemble && pnpm release:check-reproducibility",
    "release:check-reproducibility": "node scripts/check-release-reproducibility.mjs",
    "release:check-tag": "node scripts/check-release-tag.mjs",
    "f42ctl": "node tooling/f42ctl/dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "fflate": "0.8.2",
    "typescript": "^5.7.0"
  }
}
