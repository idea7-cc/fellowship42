{
  "name": "fellowship42",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @fellowship42/instance dev",
    "dev:instance": "pnpm --filter @fellowship42/instance dev",
    "dev:site": "pnpm --filter @fellowship42/project-site dev",
    "build": "pnpm -r --if-present build",
    "build:site": "pnpm --filter @fellowship42/project-site build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "check:architecture": "node scripts/check-repository-boundaries.mjs",
    "cf-typegen": "pnpm --filter @fellowship42/instance cf-typegen",
    "cf-typegen:check": "pnpm --filter @fellowship42/instance cf-typegen:check",
    "db:migrate": "pnpm --filter @fellowship42/instance db:migrate",
    "db:migrate:remote": "pnpm --filter @fellowship42/instance db:migrate:remote",
    "db:seed": "pnpm --filter @fellowship42/instance db:seed",
    "deploy:dry-run": "pnpm --filter @fellowship42/instance deploy:dry-run",
    "deploy": "pnpm --filter @fellowship42/instance deploy",
    "deploy:site:dry-run": "pnpm --filter @fellowship42/project-site deploy:dry-run",
    "deploy:site": "pnpm --filter @fellowship42/project-site deploy"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
