{
  "name": "@fellowship42/f42ctl",
  "version": "0.1.1",
  "description": "Public lifecycle planning and diagnostic CLI for Fellowship42 instances",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "f42ctl": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "cli": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "peerDependencies": {
    "@fellowship42/management-protocol": "workspace:*"
  },
  "devDependencies": {
    "@fellowship42/management-protocol": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/idea7-cc/fellowship42.git",
    "directory": "tooling/f42ctl"
  },
  "homepage": "https://github.com/idea7-cc/fellowship42#readme",
  "bugs": {
    "url": "https://github.com/idea7-cc/fellowship42/issues"
  }
}
