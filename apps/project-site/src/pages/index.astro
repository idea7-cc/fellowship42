---
/**
 * Fellowship42 Marketing Homepage
 *
 * This page is built with Astro — static HTML, zero JS by default.
 * Interactive elements (e.g. signup forms, demos) use React islands.
 * All styling comes from the shared brand token layer.
 */
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import FeatureCard from '../components/FeatureCard.astro'

const features = [
  {
    title: 'People & households',
    body: 'Manage a private, role-scoped directory with household relationships, search, lifecycle controls, audit, and conflict-safe edits.',
  },
  {
    title: 'Ministry publishing',
    body: 'Create groups, courses, lessons, events, sermons, and checksummed media while keeping drafts private and public content intentional.',
  },
  {
    title: 'Contributions & delivery',
    body: 'Keep contribution access finance-scoped, normalize signed payment events, reject replay, and recover durable outbox delivery.',
  },
  {
    title: 'One church, one instance',
    body: 'Run a dedicated Worker, D1 database, R2 bucket, Durable Object namespace, and Queue as one portable ownership boundary.',
  },
  {
    title: 'Tested portability',
    body: 'Use public manifests, doctor checks, verified exports, staged imports, cutover approval, recovery drills, and exit evidence.',
  },
  {
    title: 'Optional management',
    body: 'Connect an operator only with local owner approval. Inspect grants, rotate identity, revoke support, or disconnect without disabling the app.',
  },
]
---

<Base
  title="Fellowship42 — Portable open-source church software"
  description="An Apache-2.0 church management system built as one independent, portable Cloudflare application per church."
>
  <div class="shell">
    <Hero
      eyebrow="Open source. Managed when wanted. Portable by design."
      headline="Church software that remains yours."
      body="Fellowship42 is an Apache-2.0 church management system. Each church runs an independent Cloudflare application that can be self-hosted, professionally operated, optionally managed, exported, and moved without a private service dependency."
    >
      <a class="f42-button f42-button--primary" href="https://github.com/idea7-cc/fellowship42">View the source</a>
      <a class="f42-button f42-button--secondary" href="https://github.com/idea7-cc/fellowship42/blob/main/docs/deployment.md">Deploy an instance</a>
    </Hero>

    <section class="f42-section">
      <div class="f42-section-heading">
        <h2>The current public release</h2>
        <p>Complete public workflows and lifecycle contracts, with service claims kept separate from software evidence.</p>
      </div>
      <div class="f42-card-grid">
        {features.map((f) => (
          <FeatureCard title={f.title} body={f.body} />
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
</style>
