# Copy to .dev.vars for local-only overrides. Do not commit .dev.vars.
ENVIRONMENT=development

# Optional: protect the app with Cloudflare Access locally via a forwarded JWT.
ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
ACCESS_AUD=your-access-application-aud

# One-time production-bootstrap selector. Use the exact email in the validated
# Access JWT, and remove the deployed secret after bootstrap succeeds.
BOOTSTRAP_OWNER_EMAIL=owner@example.test

# Optional normalized payment webhook adapter. The provider name is normally a
# non-secret Wrangler variable; keep the signing key only in .dev.vars/secrets.
PAYMENT_WEBHOOK_PROVIDER=testpay
PAYMENT_WEBHOOK_SECRET=replace-with-a-unique-random-local-secret
