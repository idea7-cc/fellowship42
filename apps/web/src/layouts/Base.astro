---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Fellowship42 — Church Software',
  description = 'One system for ministries, members, giving, schedules, and public church websites.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
